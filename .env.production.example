# Production Environment Variables for Railway & Vercel Deployment

# Backend Server Configuration
PORT=8080
NODE_ENV=production

# Database Configuration (MySQL on Railway)
# Use DATABASE_URL which is automatically set by Railway
DATABASE_URL=REPLACE_ME
# Or manually set: DATABASE_URL=mysql://user:password@host:port/database

# Frontend API URL - points to Railway backend
VITE_API_URL=https://deployed-ils-wmsu-production.up.railway.app/api

# Google OAuth Configuration (Same for frontend and backend)
GOOGLE_CLIENT_ID=545992268289-4fp8qedhktkyccfhfdedkjpn2pc6.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_ME
VITE_GOOGLE_CLIENT_ID=545992268289-4fp8qedhktkyccfhfdedkjpn2pc6.apps.googleusercontent.com

# OAuth Callback URL - frontend URL
FRONTEND_URL=https://deployed-ils-wmsu.vercel.app

# Session & JWT Configuration
SESSION_SECRET=REPLACE_ME
JWT_SECRET=REPLACE_ME
JWT_EXPIRES_IN=90d

# Email Service (Brevo)
BREVO_API_KEY=REPLACE_ME
EMAIL_FROM=wmsuils.attendance@gmail.com

# Application URLs
APP_URL=https://deployed-ils-wmsu-production.up.railway.app
FRONTEND_APP_URL=https://deployed-ils-wmsu.vercel.app

# Database Connection Timeout
DB_CONNECT_TIMEOUT=60000
